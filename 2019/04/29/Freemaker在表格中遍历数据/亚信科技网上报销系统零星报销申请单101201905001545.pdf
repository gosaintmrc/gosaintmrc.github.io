    //增加遮罩
    SetShutOut("../../images/load-indicator.gif");
    window.onload = function () {
        InitPagePar();
        //隐藏遮罩层
        var content = window.document.getElementById("content");
        if (content) {
            HiddenShutOut();
            content.style.display = "none";
        }

    }

    function InitPagePar() {
        checkBr();
        var ce = $("#LabelCashExpain");
        var hx = $("#LabelWrittenOffLoan");
        var details = $("#LabelDrowHtml > table");
        $("#finId").removeClass("pageEnd");
        $("#mainTd").removeClass("pageEnd");
        if (details && details.length > 0) {
            for (var i = 0; i < details.length; i++) {
                $(details[i]).removeClass("Re");
                if (i != details.length - 1)
                    $(details[i]).addClass("pageEnd");
                else
                    $(details[i]).removeClass("pageEnd");
            }
        }
        if (hx.html()) {
            hx.removeClass("pageEnd");
            if (ce.html()) {
                ce.removeClass("Re");
                ce.addClass("pageEnd");
                return;
            }
            if (!ce.html() && details && details.length > 0) {
                $(details[details.length - 1]).addClass("pageEnd");
            }
        }

    }
    var Sys = {};
    var checkBr = function () {
        var ua = navigator.userAgent.toLowerCase();
        if (!!window.ActiveXObject || "ActiveXObject" in window)
            Sys.ie = 11;
        else if (document.getBoxObjectFor)
            Sys.firefox = ua.match(/firefox\/([\d.]+)/)[1]
        else if (window.MessageEvent && !document.getBoxObjectFor) {
            if (ua.indexOf('chrome') > 0)
                Sys.chrome = ua.match(/chrome\/([\d.]+)/)[1]
        }
        //        else if (window.opera)
        //            Sys.opera = ua.match(/opera.([\d.]+)/)[1]
        //        else if (window.openDatabase)
        //            Sys.safari = ua.match(/version\/([\d.]+)/)[1];
        else {
        }
        if (Sys.ie) {
        } else {
            //document.getElementById("mainTd").className = "pageEnd";
        }
    }
